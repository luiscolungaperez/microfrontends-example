{
  "$schema": "https://openapi.vercel.sh/microfrontends.json",
  "version": "1",
  "applications": {
    "web": {
      "packageName": "microfrontends-example-web",
      "development": {
        "fallback": "https://microfrontends-example-web.vercel.app",
        "local": 3000
      }
    },
    "second": {
      "packageName": "microfrontends-example-second",
      "development": {
        "fallback": "https://microfrontends-example-second.vercel.app",
        "local": 3001
      },
      "routing": [
        { "paths": ["/second/:path*"] }
      ]
    }
  }
}